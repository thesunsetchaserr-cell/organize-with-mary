---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Download Your Reset Kit | Organize with Mary"
  description="Your purchase is complete. Download Mary's Small Space Reset Kit here."
>

  <section class="ty-hero bg-linen">
    <div class="container--narrow text-center">
      <span class="ty-icon" aria-hidden="true">🎉</span>
      <h1 class="ty-headline">Your purchase is complete.</h1>
      <p class="ty-sub text-muted">
        Download Mary's Small Space Reset Kit below. You can save it to your device, print the pages, or use it digitally.
      </p>
    </div>
  </section>

  <section class="ty-download bg-cream">
    <div class="container--narrow text-center">
      <!-- Add final Reset Kit PDF at public/downloads/marys-small-space-reset-kit.pdf before going live. -->
      <a
        href="/downloads/marys-small-space-reset-kit.pdf"
        download
        class="btn btn--primary btn--lg ty-download-btn"
      >
        Download the Reset Kit
      </a>
      <p class="ty-bookmark text-sm text-muted">
        This page is your access page. Bookmark it or save your PDF after downloading.
      </p>
      <p class="ty-support text-sm text-muted">
        Need help? Email <a href="mailto:hello@trylucente.com">hello@trylucente.com</a>.
      </p>
    </div>
  </section>

  <section class="ty-next">
    <div class="container--content text-center">
      <h2>While you're here, start reading</h2>
      <p class="text-muted ty-next-sub">
        These guides pair directly with your kit.
      </p>
      <div class="ty-next-grid">
        <a href="/blog/renter-friendly-bathroom-storage" class="ty-next-card card">
          <div class="vis-card vis-card--landscape vis-card--bathroom ty-next-thumb">
            <span class="vis-card__icon">🪥</span>
          </div>
          <div class="ty-next-body">
            <p class="ty-next-title">17 Renter-Friendly Bathroom Storage Ideas</p>
            <span class="text-clay text-sm">Read the guide →</span>
          </div>
        </a>
        <a href="/blog/small-apartment-kitchen-organization" class="ty-next-card card">
          <div class="vis-card vis-card--landscape vis-card--kitchen ty-next-thumb">
            <span class="vis-card__icon">🍳</span>
          </div>
          <div class="ty-next-body">
            <p class="ty-next-title">Small Apartment Kitchen Organization</p>
            <span class="text-clay text-sm">Read the guide →</span>
          </div>
        </a>
        <a href="/blog/tiny-closet-organization" class="ty-next-card card">
          <div class="vis-card vis-card--landscape vis-card--closet ty-next-thumb">
            <span class="vis-card__icon">👗</span>
          </div>
          <div class="ty-next-body">
            <p class="ty-next-title">How to Organize a Tiny Closet</p>
            <span class="text-clay text-sm">Read the guide →</span>
          </div>
        </a>
      </div>
      <a href="/blog" class="btn btn--secondary mt-8">Browse All Organization Guides</a>
    </div>
  </section>

</BaseLayout>

<style>
  .ty-hero { padding-block: var(--s-16) var(--s-10); }
  .ty-icon { font-size: 3rem; display: block; margin-bottom: var(--s-5); }
  .ty-headline { font-size: clamp(1.6rem, 4vw, 2.8rem); margin-bottom: var(--s-5); }
  .ty-sub { font-size: var(--text-lg); max-width: 540px; margin-inline: auto; }

  .ty-download { padding-block: var(--s-10) var(--s-12); }
  .ty-download-btn { display: inline-block; margin-bottom: var(--s-4); }
  .ty-bookmark { margin-bottom: var(--s-2); }
  .ty-support a { color: var(--c-clay); }

  .ty-next { padding-block: var(--s-12); }
  .ty-next-sub { margin-bottom: var(--s-8); }
  .ty-next-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
    text-align: left;
  }
  .ty-next-card { text-decoration: none; display: flex; flex-direction: column; }
  .ty-next-thumb { border-radius: var(--r-lg) var(--r-lg) 0 0; min-height: 120px; }
  .ty-next-body { padding: var(--s-4); }
  .ty-next-title { font-weight: 600; color: var(--c-text); margin-bottom: var(--s-2); font-size: var(--text-base); }

  @media (max-width: 700px) {
    .ty-next-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .ty-hero { padding-block: var(--s-8) var(--s-6); }
    .ty-sub { font-size: var(--text-base); }
    .ty-download { padding-block: var(--s-8); }
    .ty-download-btn { width: 100%; text-align: center; }
    .ty-next { padding-block: var(--s-8); }
    .ty-next-sub { margin-bottom: var(--s-5); }
  }
</style>
