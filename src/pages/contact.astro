---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Organize with Mary"
  description="Contact Organize with Mary with questions about organization tips, affiliate partnerships, digital products, or anything else."
>

  <section class="contact-hero bg-warm">
    <div class="container--narrow">
      <h1 class="contact-h1">Get in touch</h1>
      <p class="contact-sub text-muted">
        Have a question about a product? A topic you'd like to see covered? An issue with a purchase? We'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container--content contact-grid">

      <div class="contact-reasons">
        <h2>What can we help with?</h2>
        <ul class="checklist contact-list">
          <li>Questions about a digital product purchase</li>
          <li>Technical issues with downloads</li>
          <li>Suggestions for future organization guides</li>
          <li>Affiliate partnership or collaboration inquiries</li>
          <li>General questions about the content on this site</li>
        </ul>

        <div class="contact-note">
          <p class="text-muted text-sm">
            <strong>Digital product issues:</strong> If you purchased the Small Space Reset Kit and are having trouble with your download, please include your order email in your message and we'll get it sorted quickly.
          </p>
        </div>
      </div>

      <div class="contact-form-area">
        <h2 class="form-area-hl">Send us a message</h2>
        <p class="form-area-sub text-muted">
          Use the form below for questions about downloads, digital products, content suggestions, or partnership inquiries.
        </p>

        <!--
          CONTACT FORM — To activate with Formspree (free, works on any host):
          1. Sign up at https://formspree.io
          2. Create a new form and copy your form ID (looks like: xpwzabcd)
          3. Replace REPLACE_WITH_YOUR_FORM_ID in the action attribute below
        -->
        <form
          class="contact-form"
          action="https://formspree.io/f/mzdqarnk"
          method="POST"
        >
          <div class="form-group">
            <label class="form-label" for="contact-name">Your name</label>
            <input class="form-input" id="contact-name" name="name" type="text" placeholder="First name" autocomplete="given-name" />
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-email">Email address</label>
            <input class="form-input" id="contact-email" name="email" type="email" placeholder="you@email.com" autocomplete="email" required />
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-subject">Subject</label>
            <select class="form-input" id="contact-subject" name="subject">
              <option value="">Select a topic...</option>
              <option>Question about a digital product</option>
              <option>Organization question</option>
              <option>Collaboration or partnership</option>
              <option>Something else</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-message">Message</label>
            <textarea class="form-input contact-textarea" id="contact-message" name="message" placeholder="How can we help?"></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--full">Send Message</button>
          <p class="form-note text-sm text-muted">We typically reply within 1–2 business days.</p>
        </form>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .contact-hero { padding-block: var(--s-12) var(--s-10); }
  .contact-h1 { margin-bottom: var(--s-3); }
  .contact-sub { font-size: var(--text-lg); }

  .contact-body { padding-block: var(--s-10) var(--s-16); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-12);
    align-items: start;
  }

  .contact-reasons h2 { margin-bottom: var(--s-5); }
  .contact-list li { margin-bottom: var(--s-3); }
  .contact-note {
    margin-top: var(--s-6);
    background: var(--c-bg-linen);
    border-radius: var(--r-md);
    padding: var(--s-4);
    border: 1px solid var(--c-border-light);
  }
  .contact-note p { margin: 0; }

  .form-area-hl { margin-bottom: var(--s-2); font-size: var(--text-xl); }
  .form-area-sub { margin-bottom: var(--s-6); font-size: var(--text-base); }

  .contact-form { display: flex; flex-direction: column; gap: var(--s-1); }
  .contact-form .form-group { margin-bottom: var(--s-4); }
  .contact-form .btn { margin-top: var(--s-2); }
  .contact-textarea { min-height: 140px; resize: vertical; }
  .form-note { margin-top: var(--s-3); margin-bottom: 0; text-align: center; }

  @media (max-width: 700px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .contact-hero { padding-block: var(--s-8) var(--s-6); }
    .contact-sub { font-size: var(--text-base); }
    .contact-body { padding-block: var(--s-8) var(--s-10); }
  }
</style>
