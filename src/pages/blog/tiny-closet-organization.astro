---
import ArticleLayout from '../../components/ArticleLayout.astro';
import ProductRecommendationCard from '../../components/ProductRecommendationCard.astro';

const toc = [
  { label: 'Start with a 20-minute closet reset',        href: '#reset' },
  { label: 'Slim hangers and vertical space',            href: '#hangers' },
  { label: 'Hanging organizers for renters',             href: '#hanging' },
  { label: 'Shoe storage for small closets',             href: '#shoes' },
  { label: 'Under-bed storage for seasonal items',       href: '#under-bed' },
  { label: 'Bulky coats and linens',                     href: '#bulky' },
  { label: 'Accessories and small items',                href: '#accessories' },
  { label: 'Product recommendations',                    href: '#products' },
  { label: 'Common tiny closet mistakes',                href: '#mistakes' },
];

const faqs = [
  {
    question: 'How do I make a tiny closet hold more without adding shelves?',
    answer: 'Switch to slim velvet hangers — they\'re about 1/3 the width of plastic hangers, which effectively triples your rod capacity. Add a double-hang rod extender for short items. Use a hanging shelf organizer for folded clothes. These three changes alone can transform a tiny closet without any permanent installation.',
  },
  {
    question: 'Can I add shelves to a rental closet without drilling?',
    answer: 'Yes. Freestanding closet systems, tension-mounted corner shelves, and hanging shelf organizers all add shelf space without permanent installation. Look for systems specifically designed to be tool-free and renter-safe.',
  },
  {
    question: 'What\'s the best way to store shoes in a small closet?',
    answer: 'Vertical is best. An over-the-door shoe organizer uses the door itself as storage. Stackable clear shoe boxes keep pairs visible and protected. A slim floor shoe rack is the simplest option for everyday shoes.',
  },
  {
    question: 'Is it worth switching to matching hangers?',
    answer: 'Yes — and it\'s one of the least expensive changes with the most visible impact. Matching slim velvet hangers unify the look of your closet, give you significantly more rod space, and prevent clothes from slipping to the floor. It\'s usually the first thing I recommend.',
  },
];

const relatedPosts = [
  { title: '17 Renter-Friendly Bathroom Storage Ideas That Don\'t Damage Walls', href: '/blog/renter-friendly-bathroom-storage', category: 'bathroom' as const },
