---
interface Props {
  price?: string;
  productName?: string;
}
const {
  price       = '$17',
  productName = "Mary's Small Space Reset Kit",
} = Astro.props;
---

<!-- STRIPE EMBEDDED CHECKOUT GOES HERE -->
<!--
  TO INTEGRATE STRIPE EMBEDDED CHECKOUT:
  1. Create a product in the Stripe Dashboard
  2. Enable Stripe Embedded Checkout in settings
  3. Follow: https://stripe.com/docs/checkout/embedded/quickstart
  4. Replace the block below with the Stripe checkout element + client script
-->

<div class="stripe-wrap">
  <div class="stripe-card">
    <div class="stripe-summary">
      <div class="stripe-product">
        <p class="stripe-name">{productName}</p>
        <p class="stripe-desc text-muted text-sm">Digital download · Instant access · Works for renters</p>
      </div>
      <p class="stripe-price">{price}</p>
    </div>

    <button class="btn btn--primary btn--lg btn--full stripe-btn" type="button">
      Get Instant Access — {price}
    </button>

    <div class="stripe-trust">
      <span>🔒 Secure checkout</span>
      <span>📧 Instant delivery by email</span>
      <span>📄 PDF download</span>
    </div>
  </div>
  <p class="stripe-placeholder-note">⚙️ Stripe Embedded Checkout placeholder — connect before launch.</p>
</div>

<style>
  .stripe-wrap { max-width: 460px; margin-inline: auto; }

  .stripe-card {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--r-xl);
    padding: var(--s-6);
    box-shadow: var(--shadow-lg);
  }

  .stripe-summary {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--s-4);
    padding-bottom: var(--s-5);
    margin-bottom: var(--s-5);
    border-bottom: 1px solid var(--c-border-light);
  }

  .stripe-name {
    font-weight: 700;
    font-size: var(--text-lg);
    margin-bottom: var(--s-1);
    color: var(--c-text);
  }

  .stripe-price {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    color: var(--c-clay);
    font-weight: 700;
    white-space: nowrap;
    margin: 0;
  }

  .stripe-btn { font-size: var(--text-lg); margin-bottom: var(--s-4); }

  .stripe-trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    justify-content: center;
    font-size: var(--text-xs);
    color: var(--c-text-muted);
  }

  .stripe-placeholder-note { display: none; }
</style>
