---
interface Props {
  title: string;
  excerpt: string;
  href: string;
  category?: string;
  readTime?: string;
  imgAlt?: string;
}

const {
  title,
  excerpt,
  href,
  category  = 'Organization',
  readTime  = '8 min read',
  imgAlt    = title,
} = Astro.props;
---

<article class="blog-card card">
  <a href={href} class="blog-card-image-link" tabindex="-1" aria-hidden="true">
    <div class="img-placeholder img-placeholder--landscape blog-card-img">
      {imgAlt}
    </div>
  </a>
  <div class="blog-card-body">
    <div class="blog-card-meta">
      <span class="badge badge--accent">{category}</span>
      <span class="blog-card-time text-muted text-sm">{readTime}</span>
    </div>
    <h3 class="blog-card-title">
      <a href={href}>{title}</a>
    </h3>
    <p class="blog-card-excerpt text-muted">{excerpt}</p>
    <a href={href} class="blog-card-link" aria-label={`Read: ${title}`}>
      Read the guide →
    </a>
  </div>
</article>

<style>
  .blog-card { display: flex; flex-direction: column; }

  .blog-card-image-link { display: block; }

  .blog-card-img {
    border-radius: 0;
    font-size: var(--text-sm);
  }

  .blog-card-body {
    padding: var(--s-5);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: var(--s-3);
  }

  .blog-card-title {
    font-size: var(--text-xl);
    line-height: 1.3;
  }

  .blog-card-title a {
    color: var(--c-text);
    text-decoration: none;
  }

  .blog-card-title a:hover { color: var(--c-accent); }

  .blog-card-excerpt {
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0;
  }

  .blog-card-link {
    margin-top: auto;
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--c-accent);
  }

  .blog-card-link:hover { color: var(--c-accent-dark); }
</style>
